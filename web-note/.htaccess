RewriteEngine On

# Never expose note data if a legacy /data directory still exists under the web root.
RewriteRule ^data(?:/.*)?$ - [R=404,L]

# Existing files/directories go through directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Everything else goes to front controller
RewriteRule ^ index.php [QSA,L]
